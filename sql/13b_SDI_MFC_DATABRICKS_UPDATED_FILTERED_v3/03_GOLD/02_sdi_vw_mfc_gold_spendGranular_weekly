
-- =============================================
-- GOLD: Granular with WoW
-- =============================================
CREATE OR REPLACE VIEW prdrzranalytics.lab42.sdi_vw_mfc_gold_spendGranular_weekly AS

WITH latest_file AS (
  SELECT
    Quarter,
    QGP_Week,
    LOB_Supported,
    MAX(FileLoad_Date) AS latest_file_load_date
  FROM prdrzranalytics.lab42.sdi_vw_mfc_silver_spendGranular_weekly
  GROUP BY Quarter, QGP_Week, LOB_Supported
),

latest AS (
  SELECT s.*
  FROM prdrzranalytics.lab42.sdi_vw_mfc_silver_spendGranular_weekly s
  JOIN latest_file f
    ON s.Quarter       = f.Quarter
   AND s.QGP_Week      = f.QGP_Week
   AND s.LOB_Supported = f.LOB_Supported
   AND s.FileLoad_Date = f.latest_file_load_date
),

base AS (
  SELECT
    Quarter,
    Period_Start,
    Period_End,
    QGP_Week,
    Quarter_End_Date,
    FileLoad_Date,
    UPPER(TRIM(LOB_Supported)) AS LOB_Supported,
    UPPER(TRIM(Channel))       AS Channel,
    UPPER(TRIM(Tactic))        AS Tactic,
    UPPER(TRIM(Message_Type))  AS Message_Type,
    Agency,
    weekly_actual              AS spend_actual,
    weekly_forecast            AS spend_forecast,
    weekly_display             AS spend_display,
    UPPER(TRIM(week_type))     AS week_type,
    DATEDIFF(Period_End, Period_Start) + 1 AS period_days
  FROM latest
),

-- Temporarily combine both boundary week partials per QGP_Week + full grain
-- to get a full 7-day spend for WoW comparison only
boundary_combined AS (
  SELECT
    QGP_Week,
    LOB_Supported,
    Channel,
    Tactic,
    Message_Type,
    Agency,
    SUM(spend_actual) AS combined_actual
  FROM base
  WHERE week_type = 'BOUNDARY_WEEK'
  GROUP BY
    QGP_Week,
    LOB_Supported,
    Channel,
    Tactic,
    Message_Type,
    Agency
),

-- Build the WoW-ready series: normal weeks + one combined boundary row per QGP_Week
wow_series AS (
  SELECT
    QGP_Week,
    LOB_Supported,
    Channel,
    Tactic,
    Message_Type,
    Agency,
    spend_actual AS actual_for_wow
  FROM base
  WHERE week_type = 'NORMAL'

  UNION ALL

  SELECT
    QGP_Week,
    LOB_Supported,
    Channel,
    Tactic,
    Message_Type,
    Agency,
    combined_actual AS actual_for_wow
  FROM boundary_combined
),

wow_calc AS (
  SELECT
    QGP_Week,
    LOB_Supported,
    Channel,
    Tactic,
    Message_Type,
    Agency,
    actual_for_wow,
    LAG(actual_for_wow) OVER (
      PARTITION BY
        LOB_Supported,
        Channel,
        Tactic,
        Message_Type,
        Agency
      ORDER BY QGP_Week ASC
    ) AS prior_week_actual
  FROM wow_series
),

with_wow AS (
  SELECT
    b.*,
    w.prior_week_actual
  FROM base b
  LEFT JOIN wow_calc w
    ON b.QGP_Week      = w.QGP_Week
   AND b.LOB_Supported = w.LOB_Supported
   AND b.Channel       = w.Channel
   AND b.Tactic        = w.Tactic
   AND b.Message_Type  = w.Message_Type
   AND b.Agency        = w.Agency
)

SELECT
  Quarter,
  Period_Start,
  Period_End,
  QGP_Week,
  Quarter_End_Date,
  FileLoad_Date,
  LOB_Supported,
  Channel,
  Tactic,
  Message_Type,
  Agency,
  spend_actual,
  spend_forecast,
  spend_display,
  week_type,

  -- Only populate WoW on Saturday boundary row (QGP_Week != Quarter_End_Date)
  -- and normal full weeks. Quarter-end-date boundary row stays null.
  CASE
    WHEN week_type = 'NORMAL'
      AND prior_week_actual IS NOT NULL
      AND prior_week_actual != 0
      AND spend_actual IS NOT NULL
      THEN ROUND((spend_actual - prior_week_actual) / prior_week_actual * 100, 2)
    WHEN week_type = 'BOUNDARY_WEEK'
      AND QGP_Week != Quarter_End_Date
      AND prior_week_actual IS NOT NULL
      AND prior_week_actual != 0
      AND spend_actual IS NOT NULL
      THEN ROUND((spend_actual - prior_week_actual) / prior_week_actual * 100, 2)
    ELSE NULL
  END AS spend_actual_wow_pct

FROM with_wow
ORDER BY
  Quarter DESC,
  QGP_Week DESC,
  LOB_Supported,
  Channel,
  Tactic;