-- =============================================
-- GOLD: Weekly (LOB level) with WoW
-- =============================================
CREATE OR REPLACE VIEW prdrzranalytics.lab42.sdi_vw_mfc_gold_spend_weekly AS

WITH latest_file AS (
  SELECT
    Quarter,
    QGP_Week,
    LOB_Supported,
    MAX(FileLoad_Date) AS latest_file_load_date
  FROM prdrzranalytics.lab42.sdi_vw_mfc_silver_spendGranular_weekly
  GROUP BY Quarter, QGP_Week, LOB_Supported
),

latest AS (
  SELECT s.*
  FROM prdrzranalytics.lab42.sdi_vw_mfc_silver_spendGranular_weekly s
  JOIN latest_file f
    ON s.Quarter       = f.Quarter
   AND s.QGP_Week      = f.QGP_Week
   AND s.LOB_Supported = f.LOB_Supported
   AND s.FileLoad_Date = f.latest_file_load_date
),

aggregated AS (
  SELECT
    Quarter,
    MIN(Period_Start)                                                         AS Period_Start,
    MAX(Period_End)                                                           AS Period_End,
    QGP_Week,
    Quarter_End_Date,
    MAX(FileLoad_Date)                                                        AS FileLoad_Date,
    LOB_Supported,
    NULLIF(SUM(weekly_actual), 0)                                             AS spend_actual,
    NULLIF(SUM(weekly_forecast), 0)                                           AS spend_forecast,
    COALESCE(NULLIF(SUM(weekly_actual), 0), NULLIF(SUM(weekly_forecast), 0)) AS spend_display,
    UPPER(TRIM(week_type))                                                    AS week_type,
    DATEDIFF(MAX(Period_End), MIN(Period_Start)) + 1                         AS period_days
  FROM latest
  GROUP BY
    Quarter,
    QGP_Week,
    Quarter_End_Date,
    LOB_Supported,
    week_type
),

-- Combine both boundary week partials that belong to the same calendar week
-- Group by Monday of the week so both partials (different QGP_Weeks) pair correctly
-- Use MAX(QGP_Week) to key on the Saturday date
boundary_combined AS (
  SELECT
    MAX(QGP_Week)     AS QGP_Week,
    LOB_Supported,
    SUM(spend_actual) AS combined_actual
  FROM aggregated
  WHERE week_type = 'BOUNDARY_WEEK'
  GROUP BY
    DATE_TRUNC('week', Period_Start),
    LOB_Supported
),

-- Build the WoW-ready series: normal weeks + one combined boundary row per calendar week
wow_series AS (
  SELECT
    QGP_Week,
    LOB_Supported,
    spend_actual AS actual_for_wow
  FROM aggregated
  WHERE week_type = 'NORMAL'

  UNION ALL

  SELECT
    QGP_Week,
    LOB_Supported,
    combined_actual AS actual_for_wow
  FROM boundary_combined
),

wow_calc AS (
  SELECT
    QGP_Week,
    LOB_Supported,
    actual_for_wow,
    LAG(actual_for_wow) OVER (
      PARTITION BY LOB_Supported
      ORDER BY QGP_Week ASC
    ) AS prior_week_actual
  FROM wow_series
),

with_wow AS (
  SELECT
    a.*,
    w.prior_week_actual
  FROM aggregated a
  LEFT JOIN wow_calc w
    ON a.QGP_Week      = w.QGP_Week
   AND a.LOB_Supported = w.LOB_Supported
   -- Only join WoW for normal weeks and Saturday boundary rows
   -- Quarter-end boundary rows never get prior_week_actual
   AND (
     a.week_type = 'NORMAL'
     OR (a.week_type = 'BOUNDARY_WEEK' AND a.QGP_Week != a.Quarter_End_Date)
   )
)

SELECT
  Quarter,
  Period_Start,
  Period_End,
  QGP_Week,
  Quarter_End_Date,
  FileLoad_Date,
  LOB_Supported,
  spend_actual,
  spend_forecast,
  spend_display,
  week_type,

  CASE
    WHEN prior_week_actual IS NOT NULL
      AND prior_week_actual != 0
      AND spend_actual IS NOT NULL
      THEN ROUND((spend_actual - prior_week_actual) / prior_week_actual * 100, 2)
    ELSE NULL
  END AS spend_actual_wow_pct

FROM with_wow
ORDER BY
  LOB_Supported DESC,
  Quarter DESC,
  QGP_Week DESC;

