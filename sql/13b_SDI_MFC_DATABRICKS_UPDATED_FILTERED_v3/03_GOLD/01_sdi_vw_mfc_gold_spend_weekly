CREATE OR REPLACE VIEW prdrzranalytics.lab42.sdi_vw_mfc_gold_spend_weekly AS

WITH latest_file AS (
  SELECT
    Quarter,
    QGP_Week,
    LOB_Supported,
    MAX(FileLoad_Date) AS latest_file_load_date
  FROM prdrzranalytics.lab42.sdi_vw_mfc_silver_spendGranular_weekly
  GROUP BY Quarter, QGP_Week, LOB_Supported
),

latest AS (
  SELECT s.*
  FROM prdrzranalytics.lab42.sdi_vw_mfc_silver_spendGranular_weekly s
  JOIN latest_file f
    ON s.Quarter       = f.Quarter
   AND s.QGP_Week      = f.QGP_Week
   AND s.LOB_Supported = f.LOB_Supported
   AND s.FileLoad_Date = f.latest_file_load_date
)

SELECT
  Quarter,
  MIN(Period_Start)                                                         AS Period_Start,
  MAX(Period_End)                                                           AS Period_End,
  QGP_Week,
  Quarter_End_Date,
  MAX(FileLoad_Date)                                                        AS FileLoad_Date,
  LOB_Supported,
  NULLIF(SUM(weekly_actual), 0)                                             AS spend_actual,
  NULLIF(SUM(weekly_forecast), 0)                                           AS spend_forecast,
  COALESCE(NULLIF(SUM(weekly_actual), 0), NULLIF(SUM(weekly_forecast), 0)) AS spend_display,
  UPPER(TRIM(week_type))                                                    AS week_type
FROM latest
GROUP BY
  Quarter,
  QGP_Week,
  Quarter_End_Date,
  LOB_Supported,
  week_type
ORDER BY
  LOB_Supported DESC, 
  Quarter DESC,
  QGP_Week DESC;