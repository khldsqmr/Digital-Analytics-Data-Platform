CREATE OR REPLACE VIEW prdrzranalytics.lab42.sdi_vw_mfc_bronze_spendGranular_weekly AS

WITH weekly_snapshots AS (
  SELECT
    Quarter,
    Week_Beginning_Monday,
    Week_Ending_Sunday,
    QGP_Week,
    FileLoad_Date,
    LOB_Supported,
    Channel,
    Tactic,
    Message_Type,
    SUM(Spend_Actual)   AS weekly_actual,
    SUM(Spend_Forecast) AS weekly_forecast,
    COALESCE(NULLIF(SUM(Spend_Actual), 0), SUM(Spend_Forecast)) AS weekly_display
  FROM prdrzranalytics.lab42.raw_media_flowchart
  WHERE LOB_Supported = 'Consumer Postpaid'
    AND WM_V_NWM = 'Working'
    AND Channel IS NOT NULL
    AND Channel NOT IN ('OTHER (do not use)', 'Non-Working', 'Unallocated', 'Budget Held')
  GROUP BY
    Quarter, Week_Beginning_Monday, Week_Ending_Sunday, QGP_Week, FileLoad_Date,
    LOB_Supported, Channel, Tactic, Message_Type
),
ranked AS (
  SELECT
    *,
    ROW_NUMBER() OVER (
      PARTITION BY Quarter, QGP_Week, LOB_Supported, Channel, Tactic, Message_Type
      ORDER BY FileLoad_Date DESC
    ) AS rn
  FROM weekly_snapshots
),
best AS (
  SELECT * FROM ranked WHERE rn = 1
),
week_type AS (
  SELECT
    QGP_Week,
    CASE WHEN COUNT(DISTINCT Quarter) > 1 THEN 'boundary_week' ELSE 'normal' END AS week_type
  FROM best
  GROUP BY QGP_Week
)
SELECT
  b.Quarter,
  b.Week_Beginning_Monday,
  b.Week_Ending_Sunday,
  b.QGP_Week,
  b.FileLoad_Date,
  b.LOB_Supported,
  b.Channel,
  b.Tactic,
  b.Message_Type,
  b.weekly_actual,
  b.weekly_forecast,
  b.weekly_display,
  w.week_type
FROM best b
JOIN week_type w ON b.QGP_Week = w.QGP_Week
WHERE b.weekly_display != 0
ORDER BY
  b.QGP_Week DESC,
  CAST(SUBSTR(b.Quarter, 4, 2) AS INT) DESC,
  CAST(SUBSTR(b.Quarter, 2, 1) AS INT) DESC,
  b.Channel,
  b.Tactic;