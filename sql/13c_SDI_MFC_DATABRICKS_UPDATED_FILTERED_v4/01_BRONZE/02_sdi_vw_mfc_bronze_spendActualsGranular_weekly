
-- ============================================================
-- BRONZE 2: ACTUALS - GRANULAR
-- Output grain:
--   Quarter
--   + QGP_Week
--   + LOB_Supported
--   + Channel
--   + Tactic
--   + Message_Type
--   + Agency
--
-- Critical change:
--   Choose the latest actual snapshot at LOB-week level FIRST.
--   Do not rank each detailed combination independently.
-- ============================================================
CREATE OR REPLACE VIEW
  prdrzranalytics.lab42.sdi_vw_mfc_bronze_spendActualsGranular_weekly
AS

WITH granular_weekly_snapshots AS (
  SELECT
    Quarter,
    Week_Beginning_Monday,
    Week_Ending_Sunday,
    QGP_Week,
    FileLoad_Date,
    UPPER(TRIM(LOB_Supported)) AS LOB_Supported,

    Channel,
    Tactic,
    Message_Type,

    CASE
      WHEN LOWER(TRIM(Agency)) = 'ini'
        THEN 'Initiative'

      WHEN LOWER(TRIM(Agency)) IN (
             'in house',
             'inhouse',
             'internal',
             'progact',
             'search'
           )
        THEN 'In-House (TMO)'

      WHEN Agency IS NULL
        THEN NULL

      ELSE TRIM(Agency)
    END AS Agency,

    SUM(Spend_Actual) AS weekly_actual

  FROM prdrzranalytics.lab42.raw_media_flowchart

  WHERE UPPER(TRIM(LOB_Supported)) IN (
          'CONSUMER POSTPAID',
          'BROADBAND'
        )
    AND WM_V_NWM = 'Working'
    AND Channel IS NOT NULL
    AND Channel NOT IN (
          'OTHER (do not use)',
          'Non-Working',
          'Unallocated',
          'Budget Held'
        )
    AND Week_Beginning_Monday <= Week_Ending_Sunday
    AND Spend_Actual IS NOT NULL
    AND UPPER(TRIM(Message_Type)) NOT IN ('MICRO')
    AND UPPER(TRIM(Message)) NOT IN (
          'SEM POSTPAID/MICRO',
          'MICRO POSTPAID OFFERS'
        )

  GROUP BY
    Quarter,
    Week_Beginning_Monday,
    Week_Ending_Sunday,
    QGP_Week,
    FileLoad_Date,
    UPPER(TRIM(LOB_Supported)),
    Channel,
    Tactic,
    Message_Type,

    CASE
      WHEN LOWER(TRIM(Agency)) = 'ini'
        THEN 'Initiative'

      WHEN LOWER(TRIM(Agency)) IN (
             'in house',
             'inhouse',
             'internal',
             'progact',
             'search'
           )
        THEN 'In-House (TMO)'

      WHEN Agency IS NULL
        THEN NULL

      ELSE TRIM(Agency)
    END
),

/* Roll granular records back to the authoritative snapshot grain. */
lob_snapshot_totals AS (
  SELECT
    Quarter,
    QGP_Week,
    FileLoad_Date,
    LOB_Supported,
    SUM(weekly_actual) AS lob_weekly_actual

  FROM granular_weekly_snapshots

  GROUP BY
    Quarter,
    QGP_Week,
    FileLoad_Date,
    LOB_Supported
),

ranked_lob_snapshots AS (
  SELECT
    *,
    ROW_NUMBER() OVER (
      PARTITION BY
        Quarter,
        QGP_Week,
        LOB_Supported
      ORDER BY
        FileLoad_Date DESC
    ) AS rn

  FROM lob_snapshot_totals

  WHERE lob_weekly_actual IS NOT NULL
    AND lob_weekly_actual != 0
),

selected_lob_snapshot AS (
  SELECT
    Quarter,
    QGP_Week,
    LOB_Supported,
    FileLoad_Date AS selected_file_load_date

  FROM ranked_lob_snapshots

  WHERE rn = 1
),

best AS (
  SELECT
    detail.*

  FROM granular_weekly_snapshots detail

  INNER JOIN selected_lob_snapshot selected
    ON  detail.Quarter       = selected.Quarter
    AND detail.QGP_Week      = selected.QGP_Week
    AND detail.LOB_Supported = selected.LOB_Supported
    AND detail.FileLoad_Date = selected.selected_file_load_date

  WHERE detail.weekly_actual IS NOT NULL
    AND detail.weekly_actual != 0
),

week_type AS (
  SELECT
    QGP_Week,
    CASE
      WHEN COUNT(DISTINCT Quarter) > 1 THEN 'boundary_week'
      ELSE 'normal'
    END AS week_type

  FROM best

  GROUP BY
    QGP_Week
)

SELECT
  b.Quarter,
  b.Week_Beginning_Monday,
  b.Week_Ending_Sunday,
  b.QGP_Week,
  b.FileLoad_Date,
  b.LOB_Supported,
  b.Channel,
  b.Tactic,
  b.Message_Type,
  b.Agency,
  b.weekly_actual,
  w.week_type

FROM best b

INNER JOIN week_type w
  ON b.QGP_Week = w.QGP_Week
;

