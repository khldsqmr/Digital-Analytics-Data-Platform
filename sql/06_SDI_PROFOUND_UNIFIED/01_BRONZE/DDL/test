SELECT
  date_yyyymmdd,
  SAFE.PARSE_DATE('%Y%m%d', date_yyyymmdd) AS parsed_date,
  FORMAT_DATE('%A', SAFE.PARSE_DATE('%Y%m%d', date_yyyymmdd)) AS day_name
FROM `prj-dbi-prd-1.ds_dbi_improvado_master.sdi_seo_profound_vis_asset_weekly_tmo`
WHERE SAFE.PARSE_DATE('%Y%m%d', date_yyyymmdd) IS NOT NULL
ORDER BY parsed_date DESC
LIMIT 20;