def detect_bq_dataset_location(default_location: str = "US") -> str:
    """
    Detect the actual BigQuery dataset location.

    This prevents query failures caused by using the wrong BQ_LOCATION.
    If the dataset does not exist yet, return default_location so the dataset
    can be created later by ensure_dataset_and_tables().
    """
    dataset_id = f"{PROJECT_ID}.{DATASET_ID}"

    try:
        dataset = bq_client.get_dataset(dataset_id)
        detected_location = dataset.location

        print(f"Detected BigQuery dataset location: {detected_location}")
        return detected_location

    except NotFound:
        print(f"Dataset does not exist yet: {dataset_id}")
        print(f"Using default BigQuery location for dataset creation: {default_location}")
        return default_location


BQ_LOCATION = detect_bq_dataset_location()
