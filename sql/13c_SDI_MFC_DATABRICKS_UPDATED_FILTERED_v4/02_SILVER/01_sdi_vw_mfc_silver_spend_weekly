-- ============================================================
-- MFC SPEND PIPELINE: TWO SILVERS + FOUR GOLDS
-- REVISION V6:
--   WoW now compares complete calendar weeks across quarter boundaries.
--
--   New field:
--     spend_actual_for_wow
--
--   Example:
--     2026-03-31 partial fragment = 9.8
--     2026-04-04 partial fragment = 11.2
--
--     For 2026-04-04:
--       spend_actual         = 11.2
--       spend_actual_for_wow = 9.8 + 11.2
--       spend_for_wow        = 2026-03-28 full-week actual
--
--     For 2026-04-11:
--       spend_actual_for_wow = 2026-04-11 full-week actual
--       spend_for_wow        = 9.8 + 11.2
--
-- REVISION V4:
--   Fixed quarter-end partial-week detection.
--   For a QGP_Week that is not a Saturday (for example 2026-03-31),
--   Period_Start now resolves to the prior Sunday rather than QGP_Week - 6 days.
--   This ensures:
--     * quarter-end partial rows are labeled Partial
--     * quarter-end partial rows have spend_for_wow = NULL
--     * the first row of the next quarter uses the previous quarter's
--       final FULL week rather than the quarter-end partial row
--
-- Databricks / Spark SQL
--
-- IMPORTANT:
--   * Existing bronze views remain unchanged.
--   * Non-granular and granular branches remain independent.
--   * QGP_Week is the ONLY reporting week field introduced.
--   * No QGP_Date column is used.
--
-- WoW business rules:
--   1. Quarter-end partial rows remain visible but:
--        spend_for_wow = NULL
--   2. First QGP_Week of a quarter uses the final FULL QGP_Week
--      from the previous quarter.
--   3. Later QGP_Weeks within the quarter use the immediately
--      preceding QGP_Week in the same quarter, including a partial
--      first week.
--   4. Missing granular combinations are scaffolded and retain:
--        spend_actual  = NULL
--        spend_for_wow = NULL
--
-- Final non-granular grain:
--   QGP_Week + LOB_Supported
--
-- Final granular grain:
--   QGP_Week
--   + LOB_Supported
--   + Channel
--   + Tactic
--   + Message_Type
--   + Agency
-- ============================================================


-- ============================================================
-- SILVER 1: NON-GRANULAR / LOB-LEVEL
-- Independent branch from non-granular bronze views.
-- ============================================================
CREATE OR REPLACE VIEW
  prdrzranalytics.lab42.sdi_vw_mfc_silver_spend_weekly
AS

WITH source_joined AS (
  SELECT
    COALESCE(a.Quarter,               f.Quarter)               AS Source_Quarter,
    COALESCE(a.Week_Beginning_Monday, f.Week_Beginning_Monday) AS Week_Beginning_Monday,
    COALESCE(a.Week_Ending_Sunday,    f.Week_Ending_Sunday)    AS Week_Ending_Sunday,
    COALESCE(a.QGP_Week,              f.QGP_Week)              AS Source_QGP_Week,

    COALESCE(
      GREATEST(a.FileLoad_Date, f.FileLoad_Date),
      a.FileLoad_Date,
      f.FileLoad_Date
    ) AS FileLoad_Date,

    COALESCE(a.LOB_Supported, f.LOB_Supported) AS LOB_Supported,

    a.weekly_actual,
    f.weekly_forecast,

    COALESCE(
      NULLIF(a.weekly_actual, 0),
      NULLIF(f.weekly_forecast, 0)
    ) AS weekly_display,

    UPPER(
      TRIM(
        COALESCE(a.week_type, f.week_type)
      )
    ) AS source_week_type

  FROM prdrzranalytics.lab42.sdi_vw_mfc_bronze_spendActuals_weekly a

  FULL OUTER JOIN prdrzranalytics.lab42.sdi_vw_mfc_bronze_spendForecasts_weekly f
    ON  a.Quarter       = f.Quarter
    AND a.QGP_Week      = f.QGP_Week
    AND a.LOB_Supported = f.LOB_Supported
),

/* Existing Quarter format follows the Q1'26-style structure used
   by the current pipeline:
     SUBSTR(Quarter, 2, 1) = quarter number
     SUBSTR(Quarter, 4, 2) = two-digit year
*/
with_quarter_numbers AS (
  SELECT
    *,
    CAST(SUBSTR(Source_Quarter, 2, 1) AS INT) AS qtr_num,
    CAST(SUBSTR(Source_Quarter, 4, 2) AS INT) AS qtr_year_2digit
  FROM source_joined
),

with_source_quarter_bounds AS (
  SELECT
    *,

    TO_DATE(
      CONCAT(
        CASE
          WHEN qtr_year_2digit < 50 THEN '20'
          ELSE '19'
        END,
        LPAD(CAST(qtr_year_2digit AS STRING), 2, '0'),
        '-',
        LPAD(CAST(((qtr_num - 1) * 3) + 1 AS STRING), 2, '0'),
        '-01'
      ),
      'yyyy-MM-dd'
    ) AS Source_Quarter_Start_Date,

    LAST_DAY(
      TO_DATE(
        CONCAT(
          CASE
            WHEN qtr_year_2digit < 50 THEN '20'
            ELSE '19'
          END,
          LPAD(CAST(qtr_year_2digit AS STRING), 2, '0'),
          '-',
          LPAD(CAST(qtr_num * 3 AS STRING), 2, '0'),
          '-01'
        ),
        'yyyy-MM-dd'
      )
    ) AS Source_Quarter_End_Date

  FROM with_quarter_numbers
),

source_periods AS (
  SELECT
    *,

    GREATEST(
      Week_Beginning_Monday,
      Source_Quarter_Start_Date
    ) AS Period_Start,

    LEAST(
      Week_Ending_Sunday,
      Source_Quarter_End_Date
    ) AS Period_End,

    DATEDIFF(
      Week_Ending_Sunday,
      Week_Beginning_Monday
    ) + 1 AS source_total_week_days

  FROM with_source_quarter_bounds
),

/* Preserve the current silver behavior:
   - retain already-separated boundary rows as provided
   - prorate a normal source row when it runs beyond quarter-end
*/
normalized_weekly AS (
  SELECT
    FileLoad_Date,
    UPPER(TRIM(LOB_Supported)) AS LOB_Supported,
    Period_Start,
    Period_End,

    CASE
      WHEN source_week_type <> 'BOUNDARY_WEEK'
       AND Week_Ending_Sunday > Source_Quarter_End_Date
      THEN ROUND(
        weekly_actual
        * (
            (DATEDIFF(Source_Quarter_End_Date, Week_Beginning_Monday) + 1)
            / source_total_week_days
          ),
        2
      )
      ELSE weekly_actual
    END AS weekly_actual,

    CASE
      WHEN source_week_type <> 'BOUNDARY_WEEK'
       AND Week_Ending_Sunday > Source_Quarter_End_Date
      THEN ROUND(
        weekly_forecast
        * (
            (DATEDIFF(Source_Quarter_End_Date, Week_Beginning_Monday) + 1)
            / source_total_week_days
          ),
        2
      )
      ELSE weekly_forecast
    END AS weekly_forecast,

    CASE
      WHEN source_week_type <> 'BOUNDARY_WEEK'
       AND Week_Ending_Sunday > Source_Quarter_End_Date
      THEN ROUND(
        weekly_display
        * (
            (DATEDIFF(Source_Quarter_End_Date, Week_Beginning_Monday) + 1)
            / source_total_week_days
          ),
        2
      )
      ELSE weekly_display
    END AS weekly_display

  FROM source_periods

  WHERE Period_End >= Period_Start
),

/* Allocate retained source values across the valid calendar days
   belonging to their source quarter. */
daily_spend AS (
  SELECT
    FileLoad_Date,
    LOB_Supported,

    weekly_actual
      / (DATEDIFF(Period_End, Period_Start) + 1) AS daily_actual,

    weekly_forecast
      / (DATEDIFF(Period_End, Period_Start) + 1) AS daily_forecast,

    weekly_display
      / (DATEDIFF(Period_End, Period_Start) + 1) AS daily_display,

    EXPLODE(
      SEQUENCE(
        Period_Start,
        Period_End,
        INTERVAL 1 DAY
      )
    ) AS calendar_date

  FROM normalized_weekly
),

/* Map every calendar day to:
   - the upcoming Saturday; or
   - quarter-end when that Saturday falls outside the quarter.
*/
daily_with_qgp AS (
  SELECT
    FileLoad_Date,
    LOB_Supported,
    calendar_date,
    daily_actual,
    daily_forecast,
    daily_display,

    CASE
      WHEN DATE_ADD(
             calendar_date,
             CASE
               WHEN DAYOFWEEK(calendar_date) = 7 THEN 0
               ELSE 7 - DAYOFWEEK(calendar_date)
             END
           )
           >
           LAST_DAY(
             ADD_MONTHS(
               TO_DATE(DATE_TRUNC('quarter', calendar_date)),
               2
             )
           )

      THEN LAST_DAY(
             ADD_MONTHS(
               TO_DATE(DATE_TRUNC('quarter', calendar_date)),
               2
             )
           )

      ELSE DATE_ADD(
             calendar_date,
             CASE
               WHEN DAYOFWEEK(calendar_date) = 7 THEN 0
               ELSE 7 - DAYOFWEEK(calendar_date)
             END
           )
    END AS QGP_Week

  FROM daily_spend
),

aggregated_existing AS (
  SELECT
    QGP_Week,
    MAX(FileLoad_Date) AS FileLoad_Date,
    LOB_Supported,

    NULLIF(ROUND(SUM(daily_actual),   2), 0) AS spend_actual,
    NULLIF(ROUND(SUM(daily_forecast), 2), 0) AS spend_forecast,
    NULLIF(ROUND(SUM(daily_display),  2), 0) AS spend_display

  FROM daily_with_qgp

  GROUP BY
    QGP_Week,
    LOB_Supported
),

/* Build a continuous calendar spine so that reporting weeks do not
   disappear merely because source rows are missing. */
calendar_bounds AS (
  SELECT
    MIN(calendar_date) AS min_calendar_date,
    MAX(calendar_date) AS max_calendar_date
  FROM daily_with_qgp
),

calendar_days AS (
  SELECT
    EXPLODE(
      SEQUENCE(
        min_calendar_date,
        max_calendar_date,
        INTERVAL 1 DAY
      )
    ) AS calendar_date

  FROM calendar_bounds
),

calendar_days_with_qgp AS (
  SELECT
    calendar_date,

    CASE
      WHEN DATE_ADD(
             calendar_date,
             CASE
               WHEN DAYOFWEEK(calendar_date) = 7 THEN 0
               ELSE 7 - DAYOFWEEK(calendar_date)
             END
           )
           >
           LAST_DAY(
             ADD_MONTHS(
               TO_DATE(DATE_TRUNC('quarter', calendar_date)),
               2
             )
           )

      THEN LAST_DAY(
             ADD_MONTHS(
               TO_DATE(DATE_TRUNC('quarter', calendar_date)),
               2
             )
           )

      ELSE DATE_ADD(
             calendar_date,
             CASE
               WHEN DAYOFWEEK(calendar_date) = 7 THEN 0
               ELSE 7 - DAYOFWEEK(calendar_date)
             END
           )
    END AS QGP_Week

  FROM calendar_days
),

qgp_calendar AS (
  SELECT DISTINCT
    QGP_Week,

    TO_DATE(
      DATE_TRUNC('quarter', QGP_Week)
    ) AS Quarter_Start_Date,

    LAST_DAY(
      ADD_MONTHS(
        TO_DATE(DATE_TRUNC('quarter', QGP_Week)),
        2
      )
    ) AS Quarter_End_Date,

    GREATEST(
      DATE_SUB(QGP_Week, DAYOFWEEK(QGP_Week) - 1),
      TO_DATE(DATE_TRUNC('quarter', QGP_Week))
    ) AS Period_Start,

    QGP_Week AS Period_End,

    DATEDIFF(
      QGP_Week,
      GREATEST(
        DATE_SUB(QGP_Week, DAYOFWEEK(QGP_Week) - 1),
        TO_DATE(DATE_TRUNC('quarter', QGP_Week))
      )
    ) + 1 AS period_days

  FROM calendar_days_with_qgp
),

qgp_file_dates AS (
  SELECT
    QGP_Week,
    MAX(FileLoad_Date) AS FileLoad_Date
  FROM aggregated_existing
  GROUP BY QGP_Week
),

lob_universe AS (
  SELECT DISTINCT
    LOB_Supported
  FROM aggregated_existing
),

complete_scaffold AS (
  SELECT
    cal.QGP_Week,
    cal.Quarter_Start_Date,
    cal.Quarter_End_Date,
    cal.Period_Start,
    cal.Period_End,
    cal.period_days,
    qfd.FileLoad_Date,
    lob.LOB_Supported

  FROM qgp_calendar cal

  LEFT JOIN qgp_file_dates qfd
    ON cal.QGP_Week = qfd.QGP_Week

  CROSS JOIN lob_universe lob
),

dense_spend AS (
  SELECT
    scaffold.QGP_Week,
    scaffold.Quarter_Start_Date,
    scaffold.Quarter_End_Date,
    scaffold.Period_Start,
    scaffold.Period_End,
    scaffold.period_days,

    COALESCE(
      actuals.FileLoad_Date,
      scaffold.FileLoad_Date
    ) AS FileLoad_Date,

    scaffold.LOB_Supported,

    actuals.spend_actual,
    actuals.spend_forecast,
    actuals.spend_display,

    CASE
      WHEN scaffold.period_days < 7 THEN 'Partial'
      ELSE 'Full'
    END AS is_partial_week,

    CASE
      WHEN scaffold.period_days < 7
       AND scaffold.QGP_Week = scaffold.Quarter_End_Date
      THEN TRUE
      ELSE FALSE
    END AS is_quarter_end_partial

  FROM complete_scaffold scaffold

  LEFT JOIN aggregated_existing actuals
    ON  scaffold.QGP_Week      = actuals.QGP_Week
    AND scaffold.LOB_Supported = actuals.LOB_Supported
),

/* ------------------------------------------------------------
   Assign each QGP fragment to its enclosing calendar week ending
   Saturday.

   Example:
     2026-03-31 -> 2026-04-04
     2026-04-04 -> 2026-04-04

   The two quarter-boundary fragments are combined when they
   represent one complete calendar week.
   ------------------------------------------------------------ */
with_calendar_week_end AS (
  SELECT
    *,

    DATE_ADD(
      QGP_Week,
      CASE
        WHEN DAYOFWEEK(QGP_Week) = 7 THEN 0
        ELSE 7 - DAYOFWEEK(QGP_Week)
      END
    ) AS calendar_week_end

  FROM dense_spend
),

/* ------------------------------------------------------------
   Complete current calendar-week actual for each LOB.

   If any required QGP fragment is missing, the complete-week
   value remains NULL rather than treating the missing fragment
   as zero.
   ------------------------------------------------------------ */
calendar_week_actuals AS (
  SELECT
    calendar_week_end,
    LOB_Supported,

    CASE
      WHEN COUNT(spend_actual) = COUNT(*)
      THEN SUM(spend_actual)
      ELSE NULL
    END AS complete_calendar_week_actual

  FROM with_calendar_week_end

  GROUP BY
    calendar_week_end,
    LOB_Supported
),

with_complete_week_values AS (
  SELECT
    current_row.*,

    current_week.complete_calendar_week_actual
      AS current_complete_calendar_week_actual,

    previous_week.complete_calendar_week_actual
      AS previous_complete_calendar_week_actual

  FROM with_calendar_week_end current_row

  LEFT JOIN calendar_week_actuals current_week
    ON  current_week.calendar_week_end =
          current_row.calendar_week_end
    AND current_week.LOB_Supported =
          current_row.LOB_Supported

  LEFT JOIN calendar_week_actuals previous_week
    ON  previous_week.calendar_week_end =
          DATE_SUB(current_row.calendar_week_end, 7)
    AND previous_week.LOB_Supported =
          current_row.LOB_Supported
),

with_spend_for_wow AS (
  SELECT
    *,

    CASE
      /* Missing current fragment: retain the scaffold row but do
         not calculate WoW. */
      WHEN spend_actual IS NULL
        THEN NULL

      /* Quarter-end fragment remains visible but should not show
         a standalone WoW value. */
      WHEN is_quarter_end_partial = TRUE
        THEN NULL

      /* For a partial quarter-start Saturday such as 2026-04-04,
         this contains 2026-03-31 + 2026-04-04.
         For a normal Saturday, it equals that week's spend. */
      ELSE current_complete_calendar_week_actual
    END AS spend_actual_for_wow,

    CASE
      WHEN spend_actual IS NULL
        THEN NULL

      WHEN is_quarter_end_partial = TRUE
        THEN NULL

      /* Prior complete calendar week:
         - 2026-04-04 -> 2026-03-28
         - 2026-04-11 -> 2026-03-31 + 2026-04-04 */
      ELSE previous_complete_calendar_week_actual
    END AS spend_for_wow

  FROM with_complete_week_values
)

SELECT
  CONCAT(
    YEAR(QGP_Week),
    ' Q',
    QUARTER(QGP_Week)
  ) AS Quarter,

  Quarter_Start_Date,
  Quarter_End_Date,
  Period_Start,
  Period_End,
  QGP_Week,
  FileLoad_Date,
  LOB_Supported,

  /* Existing silver naming */
  spend_actual   AS weekly_actual,
  spend_forecast AS weekly_forecast,
  spend_display  AS weekly_display,

  /* Tableau-facing naming */
  spend_actual,
  spend_forecast,
  spend_display,
  spend_actual_for_wow,
  spend_for_wow,

  CASE
    WHEN is_partial_week = 'Partial' THEN 'BOUNDARY_WEEK'
    ELSE 'NORMAL'
  END AS week_type,

  is_partial_week

FROM with_spend_for_wow
;

