      r.mentions_sum AS exp_mentions, b.mentions_sum AS act_mentions,
      r.sov_sum AS exp_sov, b.sov_sum AS act_sov,
      r.vis_sum AS exp_vis, b.vis_sum AS act_vis
    FROM raw_agg r CROSS JOIN bronze_agg b
