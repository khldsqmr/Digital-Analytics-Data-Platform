
-- ============================================================
-- BRONZE 3: FORECASTS - NON-GRANULAR / LOB LEVEL
--
-- Forecast selection rule:
--   For each Quarter + QGP_Week + LOB_Supported:
--     select the latest forecast FileLoad_Date strictly before
--     the first actual FileLoad_Date.
-- ============================================================
CREATE OR REPLACE VIEW
  prdrzranalytics.lab42.sdi_vw_mfc_bronze_spendForecasts_weekly
AS

WITH weekly_snapshots AS (
  SELECT
    Quarter,
    Week_Beginning_Monday,
    Week_Ending_Sunday,
    QGP_Week,
    FileLoad_Date,
    UPPER(TRIM(LOB_Supported)) AS LOB_Supported,
    SUM(Spend_Forecast)        AS weekly_forecast

  FROM prdrzranalytics.lab42.raw_media_flowchart

  WHERE UPPER(TRIM(LOB_Supported)) IN (
          'CONSUMER POSTPAID',
          'BROADBAND'
        )
    AND WM_V_NWM = 'Working'
    AND Channel IS NOT NULL
    AND Channel NOT IN (
          'OTHER (do not use)',
          'Non-Working',
          'Unallocated',
          'Budget Held'
        )
    AND Week_Beginning_Monday <= Week_Ending_Sunday
    AND Spend_Forecast IS NOT NULL
    AND UPPER(TRIM(Message_Type)) NOT IN ('MICRO')
    AND UPPER(TRIM(Message)) NOT IN (
          'SEM POSTPAID/MICRO',
          'MICRO POSTPAID OFFERS'
        )

  GROUP BY
    Quarter,
    Week_Beginning_Monday,
    Week_Ending_Sunday,
    QGP_Week,
    FileLoad_Date,
    UPPER(TRIM(LOB_Supported))
),

first_actual_date AS (
  SELECT
    Quarter,
    QGP_Week,
    UPPER(TRIM(LOB_Supported)) AS LOB_Supported,
    MIN(FileLoad_Date)         AS first_actual_file_load_date

  FROM prdrzranalytics.lab42.raw_media_flowchart

  WHERE UPPER(TRIM(LOB_Supported)) IN (
          'CONSUMER POSTPAID',
          'BROADBAND'
        )
    AND WM_V_NWM = 'Working'
    AND Channel IS NOT NULL
    AND Channel NOT IN (
          'OTHER (do not use)',
          'Non-Working',
          'Unallocated',
          'Budget Held'
        )
    AND Week_Beginning_Monday <= Week_Ending_Sunday
    AND Spend_Actual IS NOT NULL
    AND Spend_Actual != 0
    AND UPPER(TRIM(Message_Type)) NOT IN ('MICRO')
    AND UPPER(TRIM(Message)) NOT IN (
          'SEM POSTPAID/MICRO',
          'MICRO POSTPAID OFFERS'
        )

  GROUP BY
    Quarter,
    QGP_Week,
    UPPER(TRIM(LOB_Supported))
),

ranked AS (
  SELECT
    snapshot.*,

    ROW_NUMBER() OVER (
      PARTITION BY
        snapshot.Quarter,
        snapshot.QGP_Week,
        snapshot.LOB_Supported
      ORDER BY
        snapshot.FileLoad_Date DESC
    ) AS rn

  FROM weekly_snapshots snapshot

  LEFT JOIN first_actual_date actual
    ON  snapshot.Quarter       = actual.Quarter
    AND snapshot.QGP_Week      = actual.QGP_Week
    AND snapshot.LOB_Supported = actual.LOB_Supported

  WHERE snapshot.weekly_forecast IS NOT NULL
    AND snapshot.weekly_forecast != 0
    AND (
      actual.first_actual_file_load_date IS NULL
      OR snapshot.FileLoad_Date < actual.first_actual_file_load_date
    )
),

best AS (
  SELECT
    *
  FROM ranked
  WHERE rn = 1
),

actuals_quarters AS (
  SELECT DISTINCT
    Quarter,
    QGP_Week,
    UPPER(TRIM(LOB_Supported)) AS LOB_Supported

  FROM prdrzranalytics.lab42.raw_media_flowchart

  WHERE UPPER(TRIM(LOB_Supported)) IN (
          'CONSUMER POSTPAID',
          'BROADBAND'
        )
    AND WM_V_NWM = 'Working'
    AND Channel IS NOT NULL
    AND Channel NOT IN (
          'OTHER (do not use)',
          'Non-Working',
          'Unallocated',
          'Budget Held'
        )
    AND Week_Beginning_Monday <= Week_Ending_Sunday
    AND Spend_Actual IS NOT NULL
    AND Spend_Actual != 0
    AND UPPER(TRIM(Message_Type)) NOT IN ('MICRO')
    AND UPPER(TRIM(Message)) NOT IN (
          'SEM POSTPAID/MICRO',
          'MICRO POSTPAID OFFERS'
        )
),

week_type AS (
  SELECT
    QGP_Week,
    CASE
      WHEN COUNT(DISTINCT Quarter) > 1 THEN 'boundary_week'
      ELSE 'normal'
    END AS week_type

  FROM (
    SELECT
      Quarter,
      QGP_Week
    FROM best

    UNION

    SELECT
      Quarter,
      QGP_Week
    FROM actuals_quarters
  )

  GROUP BY
    QGP_Week
),

boundary_dates AS (
  SELECT
    QGP_Week,
    quarter_end_in_week

  FROM (
    SELECT DISTINCT
      QGP_Week,

      CASE
        WHEN MAKE_DATE(YEAR(Week_Beginning_Monday), 3, 31)
             BETWEEN Week_Beginning_Monday AND Week_Ending_Sunday
          THEN MAKE_DATE(YEAR(Week_Beginning_Monday), 3, 31)

        WHEN MAKE_DATE(YEAR(Week_Beginning_Monday), 6, 30)
             BETWEEN Week_Beginning_Monday AND Week_Ending_Sunday
          THEN MAKE_DATE(YEAR(Week_Beginning_Monday), 6, 30)

        WHEN MAKE_DATE(YEAR(Week_Beginning_Monday), 9, 30)
             BETWEEN Week_Beginning_Monday AND Week_Ending_Sunday
          THEN MAKE_DATE(YEAR(Week_Beginning_Monday), 9, 30)

        WHEN MAKE_DATE(YEAR(Week_Beginning_Monday), 12, 31)
             BETWEEN Week_Beginning_Monday AND Week_Ending_Sunday
          THEN MAKE_DATE(YEAR(Week_Beginning_Monday), 12, 31)
      END AS quarter_end_in_week

    FROM weekly_snapshots
  )

  WHERE quarter_end_in_week IS NOT NULL
),

boundary_with_forecast AS (
  SELECT
    *

  FROM (
    SELECT
      b.Quarter         AS source_quarter,
      b.QGP_Week,
      b.Week_Beginning_Monday,
      b.Week_Ending_Sunday,
      b.FileLoad_Date,
      b.LOB_Supported,
      b.weekly_forecast AS source_forecast,
      dates.quarter_end_in_week,

      CASE
        WHEN b.Week_Beginning_Monday <= dates.quarter_end_in_week
          THEN DATEDIFF(
                 dates.quarter_end_in_week,
                 b.Week_Beginning_Monday
               ) + 1

        ELSE DATEDIFF(
               b.Week_Ending_Sunday,
               dates.quarter_end_in_week
             )
      END AS source_days,

      DATEDIFF(
        b.Week_Ending_Sunday,
        b.Week_Beginning_Monday
      ) + 1 AS total_week_days,

      CASE
        WHEN b.Week_Beginning_Monday <= dates.quarter_end_in_week
          THEN DATEDIFF(
                 b.Week_Ending_Sunday,
                 dates.quarter_end_in_week
               )

        ELSE DATEDIFF(
               dates.quarter_end_in_week,
               b.Week_Beginning_Monday
             ) + 1
      END AS missing_days

    FROM best b

    INNER JOIN week_type wt
      ON  b.QGP_Week = wt.QGP_Week
      AND wt.week_type = 'boundary_week'

    INNER JOIN boundary_dates dates
      ON b.QGP_Week = dates.QGP_Week

    WHERE NOT EXISTS (
      SELECT
        1

      FROM best other_best

      WHERE other_best.QGP_Week      = b.QGP_Week
        AND other_best.Quarter       != b.Quarter
        AND other_best.LOB_Supported = b.LOB_Supported
    )
  )

  WHERE source_days > 0
    AND missing_days > 0
),

derived_forecasts AS (
  SELECT
    actuals.Quarter,
    source.Week_Beginning_Monday,
    source.Week_Ending_Sunday,
    source.QGP_Week,
    source.FileLoad_Date,
    source.LOB_Supported,

    ROUND(
      (source.source_forecast / source.source_days)
      * source.missing_days,
      2
    ) AS weekly_forecast,

    'boundary_week' AS week_type,
    TRUE            AS is_derived

  FROM boundary_with_forecast source

  INNER JOIN actuals_quarters actuals
    ON  actuals.QGP_Week      = source.QGP_Week
    AND actuals.LOB_Supported = source.LOB_Supported
    AND actuals.Quarter       != source.source_quarter

  LEFT JOIN best existing
    ON  existing.QGP_Week      = source.QGP_Week
    AND existing.Quarter       = actuals.Quarter
    AND existing.LOB_Supported = source.LOB_Supported

  WHERE existing.Quarter IS NULL
)

SELECT
  *

FROM (
  SELECT
    b.Quarter,
    b.Week_Beginning_Monday,
    b.Week_Ending_Sunday,
    b.QGP_Week,
    b.FileLoad_Date,
    b.LOB_Supported,
    b.weekly_forecast,
    wt.week_type,
    FALSE AS is_derived

  FROM best b

  INNER JOIN week_type wt
    ON b.QGP_Week = wt.QGP_Week

  UNION ALL

  SELECT
    Quarter,
    Week_Beginning_Monday,
    Week_Ending_Sunday,
    QGP_Week,
    FileLoad_Date,
    LOB_Supported,
    weekly_forecast,
    week_type,
    is_derived

  FROM derived_forecasts
)

WHERE weekly_forecast IS NOT NULL
  AND weekly_forecast != 0
;

