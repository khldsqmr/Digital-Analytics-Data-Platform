RawDeduped AS (
  SELECT *
  FROM RawUnion
  QUALIFY ROW_NUMBER() OVER (
    PARTITION BY
      WeekSunSat,
      ChannelGroup,
      MetricName,
      SourceTable
    ORDER BY
      FileLoadDatetime DESC,
      Filename DESC,
      InsertDate DESC
  ) = 1
),

RawPivoted AS (
  SELECT
    WeekSunSat,
    ChannelGroup,

    MAX(IF(MetricName = 'UvnbPostpaid', MetricValue, NULL)) AS UvnbPostpaid,
    MAX(IF(MetricName = 'UvnbByod', MetricValue, NULL)) AS UvnbByod,

    MAX(IF(MetricName = 'CartstartPostpaid', MetricValue, NULL)) AS CartstartPostpaid,
    MAX(IF(MetricName = 'CartstartByod', MetricValue, NULL)) AS CartstartByod,

    MAX(IF(MetricName = 'OrdersPostpaid', MetricValue, NULL)) AS OrdersPostpaid,
    MAX(IF(MetricName = 'OrdersByod', MetricValue, NULL)) AS OrdersByod

  FROM RawDeduped
  GROUP BY
    WeekSunSat,
    ChannelGroup
)

SELECT
  WeekSunSat,
  ChannelGroup,

  UvnbPostpaid,
  UvnbByod,
  UvnbByod - UvnbPostpaid AS DiffUvnbByodMinusPostpaid,

  CartstartPostpaid,
  CartstartByod,
  CartstartByod - CartstartPostpaid AS DiffCartstartByodMinusPostpaid,

  OrdersPostpaid,
  OrdersByod,
  OrdersByod - OrdersPostpaid AS DiffOrdersByodMinusPostpaid,

  CASE WHEN UvnbByod > UvnbPostpaid THEN 1 ELSE 0 END AS IsUvnbByodGreaterThanPostpaid,
  CASE WHEN CartstartByod > CartstartPostpaid THEN 1 ELSE 0 END AS IsCartstartByodGreaterThanPostpaid,
  CASE WHEN OrdersByod > OrdersPostpaid THEN 1 ELSE 0 END AS IsOrdersByodGreaterThanPostpaid

FROM RawPivoted
WHERE
  UvnbByod > UvnbPostpaid
  OR CartstartByod > CartstartPostpaid
  OR OrdersByod > OrdersPostpaid

ORDER BY
  WeekSunSat DESC,
  ChannelGroup;