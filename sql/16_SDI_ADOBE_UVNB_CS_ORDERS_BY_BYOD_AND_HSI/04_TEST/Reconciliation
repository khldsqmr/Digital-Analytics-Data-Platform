/* =================================================================================================
PURPOSE:
  Return only mismatches between Bronze LTC_GROUPS and Silver ChannelGroupsPlusAll.

EXPECTED RESULT:
  Ideally returns 0 rows.
================================================================================================= */

WITH Recon AS (
  SELECT
    COALESCE(b.WeekSunSat, s.WeekSunSat) AS WeekSunSat,
    COALESCE(b.LtcGroup, s.ChannelGroup) AS ChannelGroup,

    s.UvnbPostpaid - b.UvnbPostpaid AS DiffUvnbPostpaid,
    s.UvnbHsi - b.UvnbHsi AS DiffUvnbHsi,
    s.UvnbByod - b.UvnbByod AS DiffUvnbByod,

    s.CartstartPostpaid - b.CartstartPostpaid AS DiffCartstartPostpaid,
    s.CartstartHsi - b.CartstartHsi AS DiffCartstartHsi,
    s.CartstartByod - b.CartstartByod AS DiffCartstartByod,

    s.OrdersPostpaid - b.OrdersPostpaid AS DiffOrdersPostpaid,
    s.OrdersHsi - b.OrdersHsi AS DiffOrdersHsi,
    s.OrdersByod - b.OrdersByod AS DiffOrdersByod

  FROM `prj-dbi-prd-1.ds_dbi_digitalmedia_automation.vw_sdi_adobe_bronze_uvnbCartstartOrdersByLtcGroups_Weekly` b

  FULL OUTER JOIN (
    SELECT *
    FROM `prj-dbi-prd-1.ds_dbi_digitalmedia_automation.vw_sdi_adobe_silver_uvnbCartstartOrdersByChannelGroupsPlusAll_Weekly`
    WHERE ChannelGroup <> 'ALL'
  ) s
  ON b.WeekSunSat = s.WeekSunSat
  AND b.LtcGroup = s.ChannelGroup
)

SELECT *
FROM Recon
WHERE
  COALESCE(DiffUvnbPostpaid, 0) <> 0
  OR COALESCE(DiffUvnbHsi, 0) <> 0
  OR COALESCE(DiffUvnbByod, 0) <> 0
  OR COALESCE(DiffCartstartPostpaid, 0) <> 0
  OR COALESCE(DiffCartstartHsi, 0) <> 0
  OR COALESCE(DiffCartstartByod, 0) <> 0
  OR COALESCE(DiffOrdersPostpaid, 0) <> 0
  OR COALESCE(DiffOrdersHsi, 0) <> 0
  OR COALESCE(DiffOrdersByod, 0) <> 0

ORDER BY
  WeekSunSat DESC,
  ChannelGroup;


/* =================================================================================================
PURPOSE:
  Validate directly from RAW Adobe LTC_GROUPS tables whether BYOD values are greater than Postpaid.

CHECKS:
  - CartstartByod > CartstartPostpaid
  - OrdersByod > OrdersPostpaid
  - UvnbByod > UvnbPostpaid

